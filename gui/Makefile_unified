# Makefile pour le système GUI unifié
# Gestionnaire d'agents - Système d'interface graphique consolidé

CXX = g++
CXXFLAGS = -std=c++11 -Wall -Wextra -O2
LDFLAGS = -lstdc++

# Fichiers sources
SOURCES = unified_gui_system.cpp
OBJECTS = $(SOURCES:.cpp=.o)
EXECUTABLE = agent_manager_gui_unified

# Répertoires
BIN_DIR = build
SRC_DIR = src

# Chemins complets
FULL_EXECUTABLE = $(BIN_DIR)/$(EXECUTABLE)

# Cibles
all: $(FULL_EXECUTABLE)

$(BIN_DIR):
	mkdir -p $(BIN_DIR)

$(FULL_EXECUTABLE): $(BIN_DIR) $(SRC_DIR)/$(OBJECTS)
	$(CXX) $(CXXFLAGS) -o $@ $(SRC_DIR)/$(OBJECTS) $(LDFLAGS)
	@echo "[✓] Compilation réussie: $(FULL_EXECUTABLE)"

$(SRC_DIR)/%.o: $(SRC_DIR)/%.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@
	@echo "[✓] Compilation: $<"

run: $(FULL_EXECUTABLE)
	./$(FULL_EXECUTABLE)

clean:
	rm -rf $(SRC_DIR)/*.o $(FULL_EXECUTABLE)
	@echo "[✓] Nettoyage effectué"

help:
	@echo "Cibles disponibles:"
	@echo "  make all       - Compiler le projet"
	@echo "  make run       - Compiler et exécuter"
	@echo "  make clean     - Nettoyer les fichiers compilés"
	@echo "  make help      - Afficher cette aide"

.PHONY: all run clean help
