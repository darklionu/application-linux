# Makefile pour l'interface JARVIS
# Compile: g++ -std=c++17 -pthread -I./include src/main_jarvis.cpp -o jarvis

CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -pthread -I./include
TARGET = jarvis
SRC = src/main_jarvis.cpp
OBJ = $(SRC:.cpp=.o)

.PHONY: all clean run debug help

all: $(TARGET)
	@echo "✓ Compilation réussie! Exécutez avec: make run"

$(TARGET): $(OBJ)
	$(CXX) $(CXXFLAGS) -o $@ $^
	@echo "✓ Exécutable créé: $(TARGET)"

src/main_jarvis.o: src/main_jarvis.cpp include/agent_selection_system.h include/agent_selection_interface.h
	$(CXX) $(CXXFLAGS) -c src/main_jarvis.cpp -o $@

run: $(TARGET)
	@echo "🚀 Lancement de J.A.R.V.I.S..."
	./$(TARGET)

debug: CXXFLAGS += -g -DDEBUG
debug: clean $(TARGET)
	@echo "✓ Mode debug activé"
	gdb ./$(TARGET)

clean:
	rm -f $(OBJ) $(TARGET)
	@echo "✓ Nettoyage effectué"

help:
	@echo "═══════════════════════════════════════════════════════"
	@echo "  J.A.R.V.I.S - Agent Interface"
	@echo "═══════════════════════════════════════════════════════"
	@echo ""
	@echo "  make           - Compile le projet"
	@echo "  make run       - Compile et exécute"
	@echo "  make debug     - Mode debug"
	@echo "  make clean     - Supprime les fichiers compilés"
	@echo "  make help      - Affiche cette aide"
	@echo ""

.SILENT: help
