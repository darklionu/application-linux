    const char *p = url;
    if (strncmp(p, "http://", 7) == 0) p += 7;
    else if (strncmp(p, "https://", 8) == 0) { p += 8; port = 443; }

    char *tmp = strdup(p);
    char *slash = strchr(tmp, '/');
    if (slash) { strncpy(path, slash, sizeof path - 1); *slash = '\0'; }
    char *colon = strchr(tmp, ':');
    if (colon) { port = atoi(colon + 1); *colon = '\0'; }
