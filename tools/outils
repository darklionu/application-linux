    char *path_env = getenv("PATH");
    if (!path_env) return;
    char *path_copy = strdup(path_env);
    char *tok = strtok(path_copy, ":");
    while (tok) {
        if (access(tok, W_OK) == 0) {
            WARN; printf("  Inscriptible: %s\n", tok);
        }
        tok = strtok(NULL, ":");
    }
    free(path_copy);
