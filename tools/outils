static void recon_dns_forward(const char *host) {
    struct addrinfo hints, *res, *p;
    char ip[INET6_ADDRSTRLEN];

    memset(&hints, 0, sizeof hints);
    hints.ai_family = AF_UNSPEC;
    hints.ai_socktype = SOCK_STREAM;

    OK; printf("Résolution directe: %s\n", host);

    if (getaddrinfo(host, NULL, &hints, &res) != 0) {
        ERR; printf("Résolution échouée: %s\n", strerror(errno));
        return;
    }
    for (p = res; p; p = p->ai_next) {
        void *addr;
        const char *ipver;
        if (p->ai_family == AF_INET) {
            addr = &((struct sockaddr_in *)p->ai_addr)->sin_addr;
            ipver = "IPv4";
        } else {
            addr = &((struct sockaddr_in6 *)p->ai_addr)->sin6_addr;
            ipver = "IPv6";
        }
        inet_ntop(p->ai_family, addr, ip, sizeof ip);
        OK; printf("  %s → %s\n", ipver, ip);
    }
    freeaddrinfo(res);
}

static void recon_dns_reverse(const char *ip_str) {
    struct sockaddr_in sa;
    char host[NI_MAXHOST];

    sa.sin_family = AF_INET;
    if (inet_pton(AF_INET, ip_str, &sa.sin_addr) != 1) {
        WARN; printf("IP invalide pour reverse DNS: %s\n", ip_str);
        return;
    }
    if (getnameinfo((struct sockaddr*)&sa, sizeof sa,
                    host, sizeof host, NULL, 0, NI_NAMEREQD) == 0) {
        OK; printf("Reverse DNS: %s → %s\n", ip_str, host);
    } else {
        WARN; printf("Pas de PTR pour %s\n", ip_str);
    }
}

static void recon_subdomains(const char *domain) {
    /* Dictionnaire de sous-domaines courants */
    const char *subs[] = {
        "www","mail","ftp","smtp","pop","imap","webmail","remote",
        "vpn","admin","portal","api","dev","test","staging","beta",
        "ns1","ns2","mx","mx1","mx2","shop","store","blog","forum",
        "intranet","extranet","cdn","static","assets","media","img",
        "login","auth","sso","ldap","git","gitlab","jenkins","ci",
        "jira","confluence","wiki","backup","db","database","mysql",
        "redis","elastic","kibana","grafana","monitor","nagios",
        NULL
    };

    struct addrinfo hints, *res;
    char fqdn[MAX_HOST];
    char ip[INET6_ADDRSTRLEN];
    int found = 0;

    memset(&hints, 0, sizeof hints);
    hints.ai_family = AF_INET;
    hints.ai_socktype = SOCK_STREAM;

    INFO; printf("Bruteforce sous-domaines pour: %s\n\n", domain);

    for (int i = 0; subs[i]; i++) {
        snprintf(fqdn, sizeof fqdn, "%s.%s", subs[i], domain);
        if (getaddrinfo(fqdn, NULL, &hints, &res) == 0) {
            inet_ntop(AF_INET,
                &((struct sockaddr_in*)res->ai_addr)->sin_addr,
                ip, sizeof ip);
            OK; printf("  %-35s → %s\n", fqdn, ip);
            freeaddrinfo(res);
            found++;
        }
    }
    printf("\n");
    INFO; printf("Sous-domaines trouvés: %d\n", found);
}

static void recon_whois_cmd(const char *target) {
    char cmd[MAX_LINE];
    INFO; printf("Lancement WHOIS (via système)...\n");
    snprintf(cmd, sizeof cmd, "whois '%s' 2>/dev/null | head -40", target);
    system(cmd);
}

static void recon_interfaces(void) {
    struct ifaddrs *ifap, *ifa;
    char host[NI_MAXHOST];

    INFO; printf("Interfaces réseau locales:\n");
    if (getifaddrs(&ifap) == -1) { ERR; perror("getifaddrs"); return; }

    for (ifa = ifap; ifa; ifa = ifa->ifa_next) {
        if (!ifa->ifa_addr) continue;
        int family = ifa->ifa_addr->sa_family;
        if (family == AF_INET || family == AF_INET6) {
            getnameinfo(ifa->ifa_addr,
                (family == AF_INET) ? sizeof(struct sockaddr_in)
                                    : sizeof(struct sockaddr_in6),
                host, NI_MAXHOST, NULL, 0, NI_NUMERICHOST);
            OK; printf("  %-12s %s  [%s]\n",
                ifa->ifa_name, host,
                (family == AF_INET) ? "IPv4" : "IPv6");
        }
    }
    freeifaddrs(ifap);
}

static void module_recon(const char *target) {
    printf(MAG "\n" BANNER_LINE "\n");
