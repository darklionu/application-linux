        "find /home /root -name '.env' -o -name 'config.yml' -o -name 'database.yml' 2>/dev/null",
        "grep -r 'password' /etc/mysql/ 2>/dev/null | head -5",
        NULL
    };
    for (int i = 0; patterns[i]; i++) {
        system(patterns[i]);
    }
}

static void lateral_port_scan_internal(void) {
    HEAD; printf("Scan ports sur gateway (TCP connect rapide):\n");

    /* Détermine la gateway */
    FILE *fp = popen("ip route | grep default | awk '{print $3}'", "r");
    char gw[64] = "";
    if (fp) {
        fgets(gw, sizeof gw, fp);
        gw[strcspn(gw, "\n")] = 0;
        pclose(fp);
    }
    if (!gw[0]) { WARN; printf("Gateway introuvable\n"); return; }

    INFO; printf("Gateway détectée: %s\n", gw);

    const int ports[] = {21,22,23,25,53,80,443,445,3306,3389,5432,6379,8080,8443,0};

    struct sockaddr_in sa;
    sa.sin_family      = AF_INET;
    sa.sin_addr.s_addr = inet_addr(gw);

    for (int i = 0; ports[i]; i++) {
        int s = socket(AF_INET, SOCK_STREAM, 0);
        struct timeval tv = {1, 0};
        setsockopt(s, SOL_SOCKET, SO_SNDTIMEO, &tv, sizeof tv);
        sa.sin_port = htons(ports[i]);

        if (connect(s, (struct sockaddr*)&sa, sizeof sa) == 0) {
            OK; printf("  %s:%d OUVERT\n", gw, ports[i]);
        }
        close(s);
    }
}

