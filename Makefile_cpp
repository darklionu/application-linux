CXX := g++
CXXFLAGS := -std=c++17 -Wall -Wextra -O2
TARGET := agent_manager_app
SOURCES := agent_manager_cpp.cpp main_agent_manager.cpp
OBJECTS := $(SOURCES:.cpp=.o)
HEADERS := agent_manager_cpp.h

.PHONY: all clean help run

all: $(TARGET)

$(TARGET): $(OBJECTS)
	$(CXX) $(CXXFLAGS) -o $@ $^
	@echo "[✓] Compilation réussie: $(TARGET)"

%.o: %.cpp $(HEADERS)
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	@rm -f $(OBJECTS) $(TARGET)
	@echo "[✓] Nettoyage terminé"

help:
	@echo "Commandes disponibles:"
	@echo "  make all     - Compiler l'application"
	@echo "  make clean   - Nettoyer les fichiers compilés"
	@echo "  make run     - Compiler et exécuter"
	@echo "  make help    - Afficher cette aide"

run: $(TARGET)
	@./$(TARGET)

verbose: $(TARGET)
	@./$(TARGET) --verbose
